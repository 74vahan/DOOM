# ============================================================
# ПРИМЕР файла окружения.
# Скопируй в .env (на сервере) и впиши реальные значения.
# .env добавлен в .gitignore и в git НЕ попадает.
# ============================================================

# Порт, на котором слушает Node-приложение (Nginx проксирует сюда)
PORT=3000

# Подключение к MySQL
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=doomgame
DB_USER=doomgame_user
DB_PASSWORD=придумай_надёжный_пароль
